{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the PostAura application.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "The user's profile picture URL."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user profile was created."
        }
      },
      "required": ["email", "createdAt"]
    },
    "Post": {
      "title": "Post",
      "description": "A generated LinkedIn post.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this post."
        },
        "topic": {
          "type": "string",
          "description": "The topic of the post."
        },
        "audience": {
          "type": "string",
          "description": "The target audience."
        },
        "tone": {
          "type": "string",
          "description": "The desired tone."
        },
        "content": {
          "type": "string",
          "description": "The current content of the post."
        },
        "history": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Previous versions of the post content."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the post was created."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the post was last updated."
        }
      },
      "required": ["userId", "topic", "audience", "tone", "content", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    },
    "posts/{postId}": {
      "schema": {
        "$ref": "#/entities/Post"
      },
      "description": "Stores generated posts."
    }
  }
}
