# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ⚠️  ADMIN ENVIRONMENT VARIABLES - SENSITIVE
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 
# 🔐 SECURITY NOTES:
# 1. Firebase API Key is PUBLIC by design, but should NOT appear in URLs
# 2. Keep this file in .gitignore - NEVER commit to git
# 3. These values are built into the admin bundle (not secret)
# 4. Restrict API key in Firebase Console:
#    - Settings → API restrictions → HTTP referrer restrictions
#    - Only allow: post-aura-admin.netlify.app
# 5. Admin access is protected by Firebase Auth + email whitelist
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🔐 ADMIN - DO NOT COMMIT ACTUAL VALUES
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Copy this file to .env and fill with YOUR Firebase values
# Firebase web config is PUBLIC by design, but API key should be
# restricted to specific domains in Firebase Console
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Get from Firebase Console > Project Settings > General
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# Optional: Analytics measurement ID
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# API endpoint (local dev or production)
VITE_API_URL=http://localhost:3000
