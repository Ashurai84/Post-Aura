rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - createdAt: timestamp (required, immutable)
    //   - freeGenerationsUsed: number (required)
    //   - isPro: boolean (required)
    //   - planType: string (required)
    //   - planActivatedAt: timestamp (optional)
    //   - planExpiresAt: timestamp (optional)
    //   - instamojoPaymentId: string (optional)
    //
    // Collection: posts
    // Document ID: {postId}
    // Fields:
    //   - userId: string (required, immutable)
    //   - topic: string (required)
    //   - audience: string (required)
    //   - tone: string (required)
    //   - content: string (required)
    //   - history: list of strings (optional)
    //   - createdAt: timestamp (required, immutable)
    //   - updatedAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !('field' in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    function isValidList(listField, maxSize) {
      return !('listField' in request.resource.data) ||
             (request.resource.data[listField] is list && request.resource.data[listField].size() <= maxSize);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser() {
      return hasOnlyAllowedFields(['email', 'displayName', 'photoURL', 'createdAt', 'freeGenerationsUsed', 'isPro', 'planType', 'planActivatedAt', 'planExpiresAt', 'instamojoPaymentId']) &&
             hasRequiredFields(['email', 'createdAt', 'freeGenerationsUsed', 'isPro', 'planType']) &&
             request.resource.data.email is string && request.resource.data.email.size() > 0 && request.resource.data.email.size() < 100 &&
             isValidOptionalString('displayName', 0, 100) &&
             isValidOptionalString('photoURL', 0, 500) &&
             request.resource.data.createdAt is timestamp &&
             request.resource.data.freeGenerationsUsed is number &&
             request.resource.data.isPro is bool &&
             request.resource.data.planType in ['free', 'student', 'pro'] &&
             (!('planActivatedAt' in request.resource.data) || request.resource.data.planActivatedAt == null || request.resource.data.planActivatedAt is timestamp) &&
             (!('planExpiresAt' in request.resource.data) || request.resource.data.planExpiresAt == null || request.resource.data.planExpiresAt is timestamp) &&
             (!('instamojoPaymentId' in request.resource.data) || request.resource.data.instamojoPaymentId == null || request.resource.data.instamojoPaymentId is string);
    }

    function isValidPost() {
      return hasOnlyAllowedFields(['userId', 'topic', 'audience', 'tone', 'content', 'history', 'createdAt', 'updatedAt']) &&
             hasRequiredFields(['userId', 'topic', 'audience', 'tone', 'content', 'createdAt', 'updatedAt']) &&
             request.resource.data.userId == request.auth.uid &&
             isValidString('topic', 1, 200) &&
             isValidString('audience', 1, 200) &&
             isValidString('tone', 1, 100) &&
             isValidString('content', 1, 10000) &&
             (!('history' in request.resource.data) || (request.resource.data.history is list && request.resource.data.history.size() <= 100)) &&
             request.resource.data.createdAt is timestamp &&
             request.resource.data.updatedAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser();
      // Only allow user to update non-sensitive fields. Sensitive fields (isPro, planType, etc.) are updated via backend webhook.
      allow update: if isOwner(userId) && isValidUser() && 
                    request.resource.data.createdAt == resource.data.createdAt &&
                    request.resource.data.isPro == resource.data.isPro &&
                    request.resource.data.planType == resource.data.planType &&
                    request.resource.data.freeGenerationsUsed == resource.data.freeGenerationsUsed;
      allow delete: if isOwner(userId);
    }

    match /posts/{postId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidPost();
      allow update: if isDocOwner() && isValidPost() && request.resource.data.createdAt == resource.data.createdAt && request.resource.data.userId == resource.data.userId;
      allow delete: if isDocOwner();
    }
  }
}
