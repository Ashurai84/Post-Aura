# Public web app URL for API calls (empty = same origin as the page)
VITE_API_URL=http://localhost:3000

# Firebase Web SDK — from Firebase Console → Project settings → Your apps
# These are "public" keys but still keep them out of git; lock down with App Check + domain rules in Console.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
# Use (default) or your named database id
VITE_FIREBASE_FIRESTORE_DATABASE_ID=(default)
