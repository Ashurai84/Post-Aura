rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===== AUTHENTICATION CHECK =====
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin';
    }

    // ===== USER PROFILES =====
    // Users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // ===== POSTS =====
    // Authors can read/write their own posts
    // Users can read published posts
    match /posts/{postId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.userId ||
        resource.data.published == true
      );
      allow write: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // ===== FEEDBACK =====
    // Users can submit feedback (backend writes)
    // Only backend/admin can read
    match /feedback/{feedbackId} {
      allow write: if isAuthenticated();
      allow read: if isAdmin();
    }

    // ===== ANALYTICS =====
    // Backend writes analytics
    // Frontend/Users CANNOT read
    // Only admin can read
    match /analytics/{analyticsId} {
      allow write: if isAuthenticated();
      allow read: if isAdmin();
    }

    // ===== PAYMENTS =====
    // Users can only read their own payment records
    // Backend writes new payments
    match /payments/{paymentId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow write: if isAuthenticated();
      allow read: if isAdmin();
    }

    // ===== ADMIN COLLECTION =====
    // Only admins can read admin settings
    match /admins/{adminId} {
      allow read, write: if isAdmin() && request.auth.uid == adminId;
    }

    // ===== DENY ALL OTHER ACCESS =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
